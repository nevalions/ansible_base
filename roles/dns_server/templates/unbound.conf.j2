server:
    interface: {{ dns_listen_interface }}
{% for network in vault_dns_allowed_networks | default(["0.0.0.0/0"]) %}
    access-control: {{ network }} allow
{% endfor %}
    do-ip6: {{ "yes" if dns_do_ipv6 else "no" }}
    rrset-cache-size: {{ dns_cache_size }}m
    msg-cache-size: {{ dns_cache_size }}m

    # Disable SO_REUSEPORT to prevent orphaned unbound processes from
    # binding to port 53 and stealing queries with stale cache/config.
    so-reuseport: {{ "yes" if dns_so_reuseport else "no" }}

    # Disable qname-minimisation in forwarding mode — it triggers partial
    # iterative lookups that cache broken NS referrals for TLDs (.io, .com)
    # when IPv6-only nameservers are unreachable (do-ip6: no).
    qname-minimisation: {{ "yes" if dns_qname_minimisation else "no" }}

    # Serve expired cache entries while fetching fresh data upstream.
    serve-expired: {{ "yes" if dns_serve_expired else "no" }}
    serve-expired-ttl: {{ dns_serve_expired_ttl }}

    # Prefetch popular entries before they expire, keeping cache warm.
    prefetch: {{ "yes" if dns_prefetch else "no" }}

{% if dns_dnssec_validation %}
    # DNSSEC trust anchor — refreshed by unbound-anchor in dns_server role.
    auto-trust-anchor-file: "/var/lib/unbound/root.key"
    harden-dnssec-stripped: no
    val-permissive-mode: no
    val-clean-additional: yes
{% else %}
    # DNSSEC validation disabled for forwarding-only setup.
    # Upstream resolvers already validate DNSSEC. Local validation triggers
    # iterative DS/DNSKEY lookups that cache TLD NS referrals, causing
    # intermittent ANSWER:0 responses when forwarding times out.
    module-config: "iterator"
{% endif %}

# Allow unbound-control for cache management (flush stale entries without restart).
# Without this, a poisoned or stale CNAME-chase cache entry (e.g. *.cdn.cloudflare.net
# returning ANSWER:0) persists until service restart, breaking image pulls cluster-wide.
remote-control:
    control-enable: yes
    control-interface: 127.0.0.1

{% set valid_upstreams = (dns_upstream_dns | default([])
  | reject('match', '^\[.*\]$')
  | select('match', '^(?:\d{1,3}\.){3}\d{1,3}$')
  | list) %}
{% set effective_upstreams = valid_upstreams if (valid_upstreams | length > 0) else ['77.88.8.8', '1.1.1.1', '9.9.9.9'] %}

forward-zone:
    name: "."
{% for upstream in effective_upstreams %}
    forward-addr: {{ upstream }}
{% endfor %}

include: /etc/unbound/unbound.conf.d/zone.conf
